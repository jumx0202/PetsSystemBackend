<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ynu.pet.mapper.PetLocationMapper">

    <resultMap id="LocationResultMap" type="ynu.pet.entity.PetLocation">
        <id property="id" column="id"/>
        <result property="petId" column="pet_id"/>
        <result property="latitude" column="latitude"/>
        <result property="longitude" column="longitude"/>
        <result property="speed" column="speed"/>
        <result property="source" column="source"/>
        <result property="recordedAt" column="recorded_at"/>
    </resultMap>

    <insert id="insert" parameterType="ynu.pet.entity.PetLocation" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO pet_location(pet_id, latitude, longitude, speed, source, recorded_at)
        VALUES(#{petId}, #{latitude}, #{longitude}, #{speed}, #{source}, #{recordedAt})
    </insert>

    <select id="selectLatestByPetId" parameterType="long" resultMap="LocationResultMap">
        SELECT *
        FROM pet_location
        WHERE pet_id = #{petId}
        ORDER BY recorded_at DESC
        LIMIT 1
    </select>

    <select id="selectHistoryByPetId" resultMap="LocationResultMap">
        SELECT *
        FROM pet_location
        WHERE pet_id = #{petId}
          AND recorded_at >= DATE_SUB(NOW(), INTERVAL #{hours} HOUR)
        ORDER BY recorded_at ASC
    </select>

    <select id="selectAllPetIds" resultType="long">
        SELECT id FROM Pet ORDER BY id
    </select>

</mapper>
