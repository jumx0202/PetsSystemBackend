<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ynu.pet.mapper.BehaviorModelMapper">

    <resultMap id="BehaviorModelResultMap" type="ynu.pet.entity.BehaviorModel">
        <id property="id" column="id"/>
        <result property="modelName" column="model_name"/>
        <result property="modelVersion" column="model_version"/>
        <result property="modelType" column="model_type"/>
        <result property="modelFilePath" column="model_file_path"/>
        <result property="accuracy" column="accuracy"/>
        <result property="isActive" column="is_active"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="ynu.pet.entity.BehaviorModel" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO behavior_models(model_name, model_version, model_type, model_file_path, accuracy, is_active, created_at)
        VALUES(#{modelName}, #{modelVersion}, #{modelType}, #{modelFilePath}, #{accuracy}, #{isActive}, NOW())
    </insert>

    <select id="selectById" parameterType="long" resultMap="BehaviorModelResultMap">
        SELECT *
        FROM behavior_models
        WHERE id = #{id}
    </select>

    <select id="selectActiveModels" resultMap="BehaviorModelResultMap">
        SELECT *
        FROM behavior_models
        WHERE is_active = 1
    </select>

    <select id="selectByType" parameterType="int" resultMap="BehaviorModelResultMap">
        SELECT *
        FROM behavior_models
        WHERE model_type = #{type}
          AND is_active = 1
    </select>

    <select id="selectAll" resultMap="BehaviorModelResultMap">
        SELECT *
        FROM behavior_models
    </select>

    <update id="update" parameterType="ynu.pet.entity.BehaviorModel">
        UPDATE behavior_models
        SET model_name = #{modelName},
            model_version = #{modelVersion},
            model_type = #{modelType},
            model_file_path = #{modelFilePath},
            accuracy = #{accuracy},
            is_active = #{isActive},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE behavior_models
        SET is_active = #{isActive}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM behavior_models
        WHERE id = #{id}
    </delete>

</mapper>
