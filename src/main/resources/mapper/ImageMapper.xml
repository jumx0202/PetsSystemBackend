<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ynu.pet.mapper.ImageMapper">

    <resultMap id="ImageResultMap" type="ynu.pet.entity.Image">
        <id property="id" column="id"/>
        <result property="imageUrl" column="image_url"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="adoptionPostId" column="postadoption_id"/>
        <result property="lostPostId" column="postlost_id"/>
        <association property="pet" javaType="ynu.pet.entity.Pet">
            <id property="id" column="pet_id"/>
        </association>
    </resultMap>

    <insert id="insert" parameterType="ynu.pet.entity.Image" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO Image(image_url, sort_order, postadoption_id, postlost_id, pet_id)
        VALUES(#{imageUrl}, #{sortOrder}, #{adoptionPostId}, #{lostPostId}, #{pet.id})
    </insert>

    <insert id="batchInsert">
        INSERT INTO Image(image_url, sort_order, postadoption_id, postlost_id, pet_id)
        VALUES
        <foreach collection="images" item="item" separator=",">
            (#{item.imageUrl}, #{item.sortOrder}, #{item.adoptionPostId}, #{item.lostPostId}, #{item.pet.id})
        </foreach>
    </insert>

    <select id="selectById" parameterType="long" resultMap="ImageResultMap">
        SELECT *
        FROM Image
        WHERE id = #{id}
    </select>

    <select id="selectByAdoptionPostId" parameterType="long" resultMap="ImageResultMap">
        SELECT *
        FROM Image
        WHERE postadoption_id = #{postId}
        ORDER BY sort_order
    </select>

    <select id="selectByLostPostId" parameterType="long" resultMap="ImageResultMap">
        SELECT *
        FROM Image
        WHERE postlost_id = #{postId}
        ORDER BY sort_order
    </select>

    <select id="selectByPetId" parameterType="long" resultMap="ImageResultMap">
        SELECT *
        FROM Image
        WHERE pet_id = #{petId}
        ORDER BY sort_order
    </select>

    <select id="selectByBehaviorLogId" parameterType="long" resultMap="ImageResultMap">
        SELECT *
        FROM Image
        WHERE behavior_log_id = #{logId}
    </select>

    <delete id="deleteById" parameterType="long">
        DELETE FROM Image
        WHERE id = #{id}
    </delete>

    <delete id="batchDelete">
        DELETE FROM Image
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
